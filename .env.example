# Copy this file to `.env` for local development.
# Do not commit your real `.env` or any real API keys.

# Minimal generic LLM configuration used by this project.
LLM_PROVIDER=deepseek
LLM_MODEL_ID=deepseek-chat
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com

# Optional runtime settings.
# DEBUG=false
# LOG_LEVEL=INFO
# TEMPERATURE=0.7
# MAX_HISTORY_LENGTH=100

# Optional memory / vector store settings.
# MEMORY_ENABLED=true
# VECTOR_STORE_BACKEND=auto
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_SEMANTIC_COLLECTION=semantic_memory
# QDRANT_RAG_COLLECTION=rag_chunks
# GRAPH_STORE_BACKEND=auto
# NEO4J_URL=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_password_here
# NEO4J_DATABASE=neo4j
# ENABLE_SEMANTIC_MEMORY=true

# You can also use the more generic defaults supported by Config.from_env().
# DEFAULT_PROVIDER=deepseek
# DEFAULT_MODEL=deepseek-chat
